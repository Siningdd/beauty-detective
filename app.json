{
  "expo": {
    "name": "Beauty Detective",
    "slug": "beauty-detective",
    "scheme": "beauty-detective",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./app/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "用于拍摄化妆品成分表",
        "NSPhotoLibraryUsageDescription": "用于从相册选取化妆品图片"
      }
    },
    "android": {
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./app/assets/android-icon-foreground.png",
        "backgroundImage": "./app/assets/android-icon-background.png",
        "monochromeImage": "./app/assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./app/assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
